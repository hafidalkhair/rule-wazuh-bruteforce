<group name="local,syslog,sshd,">

  <!-- Rule contoh default Wazuh -->
  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!-- Rule custom: login sukses setelah brute force (dalam 120 detik) -->
  <rule id="100002" level="15" timeframe="120">
    <if_sid>5715</if_sid>
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>CRITICAL: SSH Brute Force Attack Successful - Attacker Is Inside!</description>
    <mitre>
      <id>T1110.001</id>
      <id>T1078</id>
    </mitre>
    <group>authentication_success,attack_successful,</group>
  </rule>

  <!-- Rule custom: brute force valid user aktif terdeteksi -->
  <rule id="100003" level="14" frequency="8" timeframe="120" ignore="60">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>CRITICAL: SSH Brute Force Ongoing!</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>attack_in_progress,brute_force_detected,</group>
  </rule>

  <!-- Rule custom: brute force invalid user aktif terdeteksi -->
  <rule id="100004" level="14" frequency="8" timeframe="120" ignore="60">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>CRITICAL: SSH Brute Force (Invalid User) Ongoing!</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>attack_in_progress,brute_force_detected,</group>
  </rule>

</group>
